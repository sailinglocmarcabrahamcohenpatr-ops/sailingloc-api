###> symfony/mailer ###
# OVH Zimbra SMTP — port 465 SSL (recommandé) ou port 587 STARTTLS
# Format SSL  : smtps://votre@adresse.fr:motdepasse@ssl0.ovh.net:465
# Format TLS  : smtp://votre@adresse.fr:motdepasse@ssl0.ovh.net:587?encryption=tls
# Encode les caractères spéciaux du mot de passe (%40 pour @, %25 pour %, etc.)
MAILER_DSN=smtps://votre@adresse.fr:motdepasse@ssl0.ovh.net:465
MAILER_SENDER_EMAIL=votre@adresse.fr
MAILER_SENDER_NAME=SailingLoc
###< symfony/mailer ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://sailingloc:change_me_in_env_dev_local@database:5432/sailingloc?serverVersion=16&charset=utf8"
