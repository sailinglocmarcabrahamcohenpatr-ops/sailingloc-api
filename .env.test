# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
APP_ENV=test
APP_DEBUG=1
DEFAULT_URI=http://localhost

###> doctrine/doctrine-bundle ###
# Doctrine ajoute automatiquement le suffixe _test (voir doctrine.yaml when@test)
DATABASE_URL="postgresql://sailingloc:change_me_in_env_local@database:5432/sailingloc?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=sailingloc_jwt_passphrase
###< lexik/jwt-authentication-bundle ###
